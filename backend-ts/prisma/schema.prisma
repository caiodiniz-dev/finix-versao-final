// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String    @id @default(uuid())
  name                   String
  email                  String    @unique
  passwordHash           String
  role                   String    @default("USER")
  blocked                Boolean   @default(false)
  photo                  String?
  plan                   String    @default("FREE") // FREE | BASIC | PRO | TEST
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  transactionsUsed       Int       @default(0)
  transactionsMonth      String    @default("") // YYYY-MM for monthly reset
  planExpiresAt          DateTime?
  hasCompletedOnboarding Boolean   @default(false)
  usageType              String?
  companyName            String?
  companyLogo            String?
  businessPurpose        String?
  primaryColor           String?
  phone                  String?
  isVerified             Boolean   @default(false)
  verificationCode       String?
  verificationExpires    DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @default(now()) @updatedAt

  transactions        Transaction[]
  goals               Goal[]
  budgets             Budget[]
  paymentTransactions PaymentTransaction[]
  categories          Category[]
  subscription        Subscription?
  installments        Installment[]
  financialAlerts     FinancialAlert[]

  @@map("users")
}

model Transaction {
  id                 String   @id @default(uuid())
  userId             String
  title              String
  amount             Float
  type               String
  category           String
  description        String?
  date               DateTime
  recurring          Boolean  @default(false)
  recurringFrequency String?
  paymentMethod      String?  @default("pix")
  installments       Int      @default(1)
  installmentNumber  Int?
  totalInstallments  Int?
  totalAmount        Float?
  installmentId      String?
  currency           String   @default("BRL")
  createdAt          DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  installment Installment? @relation(fields: [installmentId], references: [id], onDelete: SetNull)

  @@map("transactions")
}

model Goal {
  id            String   @id @default(uuid())
  userId        String
  title         String
  targetAmount  Float
  currentAmount Float    @default(0)
  deadline      DateTime
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("goals")
}

model Budget {
  id        String   @id @default(uuid())
  userId    String
  category  String
  limit     Float
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@map("budgets")
}

model PaymentTransaction {
  id              String   @id @default(uuid())
  userId          String?
  userEmail       String?
  sessionId       String   @unique
  amount          Float
  currency        String   @default("brl")
  plan            String // basic | pro
  paymentStatus   String   @default("pending") // pending | paid | failed | expired
  status          String   @default("initiated")
  stripePaymentId String?
  metadata        String? // JSON string
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("payment_transactions")
}

model Category {
  id        String   @id @default(uuid())
  userId    String
  name      String
  icon      String?  @default("folder") // lucide-react icon name
  color     String?  @default("#3b82f6") // hex color
  type      String   @default("expense") // "income" | "expense" | "both"
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("categories")
}

// Plan definition (stored as reference, not duplicated per user)
model Plan {
  id          String   @id @default(uuid())
  name        String   @unique // "FREE" | "BASIC" | "PRO"
  displayName String // "Free (Trial)" | "Finix Básico" | "Finix Pro"
  price       Float    @default(0) // monthly price in BRL
  yearlyPrice Float? // annual billed price
  description String?
  features    String   @default("{}") // JSON with feature set
  limits      String   @default("{}") // JSON with limits: { "users": 1, "contacts": 50, "accounts": 2, ... }
  isActive    Boolean  @default(true)
  order       Int      @default(0) // for sorting
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

// User subscription to a plan
model Subscription {
  id               String    @id @default(uuid())
  userId           String    @unique
  planId           String
  startDate        DateTime  @default(now())
  endDate          DateTime? // null = forever (or use calculated date)
  autoRenew        Boolean   @default(true)
  stripeCustomerId String?
  stripeSubId      String?
  status           String    @default("active") // "active" | "cancelled" | "paused" | "expired"
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

// Installment for credit card expenses
model Installment {
  id              String   @id @default(uuid())
  userId          String
  description     String // "Celular", "Notebook", etc.
  totalAmount     Float // Total value
  numberOfParcels Int // Number of installments
  dueDay          Int // Day of month (1-31)
  startDate       DateTime // When first parcel starts
  status          String   @default("active") // "active" | "completed" | "cancelled"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  alerts       FinancialAlert[]
  transactions Transaction[]

  @@map("installments")
}

// Alert for installment due dates
model FinancialAlert {
  id            String    @id @default(uuid())
  userId        String
  installmentId String?
  title         String // "Parcela Celular vence amanhã"
  description   String?
  type          String    @default("installment") // "installment" | "budget" | "goal"
  severity      String    @default("info") // "info" | "warning" | "danger"
  amount        Float?
  daysUntilDue  Int?
  dueDate       DateTime?
  isRead        Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  installment Installment? @relation(fields: [installmentId], references: [id], onDelete: SetNull)

  @@map("financial_alerts")
}
